{
  "realm": "company",
  "enabled": true,
  "displayName": "Company SSO",
  "displayNameHtml": "<strong>Company SSO</strong>",
  "loginTheme": "company",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "verifyEmail": false,
  "sslRequired": "external",
  "roles": {
    "realm": [
      {
        "name": "grafana-admin",
        "description": "Grafana Admin via Keycloak"
      },
      {
        "name": "grafana-editor",
        "description": "Grafana Editor via Keycloak"
      },
      {
        "name": "grafana-viewer",
        "description": "Grafana Viewer via Keycloak"
      }
    ]
  },
  "groups": [
    {
      "name": "grafana-admins",
      "realmRoles": [
        "grafana-admin"
      ]
    },
    {
      "name": "grafana-editors",
      "realmRoles": [
        "grafana-editor"
      ]
    },
    {
      "name": "grafana-viewers",
      "realmRoles": [
        "grafana-viewer"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "grafana",
      "name": "Grafana",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "grafana-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:3000/login/generic_oauth"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "client.secret.creation.time": "1710000000",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "grafana-admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Grafana",
      "lastName": "Admin",
      "email": "grafana-admin@example.local",
      "credentials": [
        {
          "type": "password",
          "value": "Admin123456",
          "temporary": false
        }
      ],
      "realmRoles": [
        "grafana-admin"
      ],
      "groups": [
        "grafana-admins"
      ]
    },
    {
      "username": "grafana-editor",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Grafana",
      "lastName": "Editor",
      "email": "grafana-editor@example.local",
      "credentials": [
        {
          "type": "password",
          "value": "Editor123456",
          "temporary": false
        }
      ],
      "realmRoles": [
        "grafana-editor"
      ],
      "groups": [
        "grafana-editors"
      ]
    },
    {
      "username": "grafana-viewer",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Grafana",
      "lastName": "Viewer",
      "email": "grafana-viewer@example.local",
      "credentials": [
        {
          "type": "password",
          "value": "Viewer123456",
          "temporary": false
        }
      ],
      "realmRoles": [
        "grafana-viewer"
      ],
      "groups": [
        "grafana-viewers"
      ]
    }
  ],
  "scopeMappings": [
    {
      "client": "grafana",
      "roles": [
        "grafana-admin",
        "grafana-editor",
        "grafana-viewer"
      ]
    }
  ]
}